{
  "name": "@takaro/connector",
  "version": "0.0.1",
  "description": "Handles persistent connections to gameservers",
  "main": "dist/main.js",
  "types": "main.ts",
  "type": "module",
  "scripts": {
    "start": "node --loader ../../node_modules/@takaro/util/dist/tracing.js dist/main.js",
    "start:dev": "nodemon --exec 'npm run build && node --inspect=0.0.0.0:12001 --loader ../../node_modules/@takaro/util/dist/tracing.js dist/main.js' --config ../../nodemon.json",
    "build": "tsc -p ./tsconfig.build.json",
    "test": "npm run test:unit --if-present && npm run test:integration --if-present",
    "test:unit": "tsc -p ./tsconfig.json && mocha --config ../../.mocharc.js dist/**/*.unit.test.js --exit",
    "test:integration": "tsc -p ./tsconfig.json && mocha --file ../test/dist/waitUntilReady.js --config ../../.mocharc.js dist/**/*.integration.test.js --exit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@takaro/http": "0.0.1",
    "@takaro/apiclient": "0.0.1",
    "@takaro/gameserver": "0.0.1",
    "@takaro/queues": "0.0.1",
    "@takaro/auth": "0.0.1",
    "@takaro/util": "0.0.1"
  },
  "devDependencies": {}
}